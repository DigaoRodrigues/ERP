# Project Configuration
PROJECT_NAME=ERP Multi-Tenant API
VERSION=0.1.0
ENVIRONMENT=development

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_db

# JWT Authentication
# IMPORTANT: Generate a strong random secret key for production
# You can generate one with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-strong-random-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Integration
# Supported providers: claude | openai | xai
AI_PROVIDER=claude
AI_API_KEY=your-ai-api-key-here

# CORS Configuration
# Supports three formats:
# 1. JSON array: ["http://localhost:3000","https://example.com"]
# 2. Comma-separated: http://localhost:3000,https://example.com
# 3. Single string: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Railway Production Example:
# DATABASE_URL=postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway
# JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
# ALLOWED_ORIGINS=["https://your-frontend.railway.app","https://your-backend.railway.app"]
# ENVIRONMENT=production